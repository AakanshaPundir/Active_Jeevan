<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: 'Montserrat', sans-serif;
        }

        body{
            background:#131b2b;
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            color:white;
            overflow-y:auto;
            padding:20px;
        }

        .container{
            width:100%;
            max-width:450px;
        }

        .form-box{
            background:rgba(255,255,255,0.08);
            backdrop-filter: blur(10px);
            padding:35px;
            border-radius:15px;
            box-shadow:0 8px 20px rgba(0,0,0,0.4);
        }

        h1{
            text-align:center;
            margin-bottom:25px;
            color:white;
            font-size:32px;
        }

        .error-message{
            background:#ff4d4d;
            color:white;
            padding:12px;
            border-radius:8px;
            margin-bottom:15px;
            text-align:center;
            font-size:14px;
        }

        label{
            display:block;
            margin-bottom:6px;
            margin-top:14px;
            font-weight:600;
            font-size:14px;
        }

        input{
            width:100%;
            padding:12px;
            border:none;
            border-radius:8px;
            background:#222;
            color:white;
            outline:none;
            border:1px solid #444;
            font-size:14px;
            transition:0.3s;
        }

        input:focus{
            border:1px solid white;
            background:#2b2b2b;
        }

        input::placeholder{
            color:#aaa;
        }

        button{
            width:100%;
            padding:13px;
            margin-top:22px;
            border:none;
            border-radius:8px;
            background:white;
            color:black;
            font-size:15px;
            font-weight:bold;
            cursor:pointer;
            transition:0.3s;
        }

        button:hover{
            background:#ddd;
            transform:translateY(-2px);
        }

        .terms{
            margin-top:18px;
            display:flex;
            align-items:flex-start;
            gap:10px;
            font-size:14px;
            line-height:1.4;
        }

        .terms input{
            width:auto;
            margin-top:3px;
        }

        .terms label{
            margin:0;
            font-weight:normal;
        }

        a{
            color:white;
            text-decoration:none;
            font-weight:600;
        }

        a:hover{
            text-decoration:underline;
        }

        .login-link{
            text-align:center;
            margin-top:20px;
            font-size:14px;
        }

        @media(max-width:500px){

            .form-box{
                padding:25px;
            }

            h1{
                font-size:28px;
            }

        }
    </style>
</head>

<body>

<div class="container">

    <div class="form-box">

        <h1>Create Account</h1>

        <% if (typeof error !== 'undefined') { %>
            <div class="error-message">
                <%= error %>
            </div>
        <% } %>

        <form action="/register" method="POST">

            <label for="name">Full Name</label>
            <input 
                type="text" 
                id="name" 
                name="name" 
                placeholder="Enter your full name"
                required
            >

            <label for="email">Email Address</label>
            <input 
                type="email" 
                id="email" 
                name="email"
                placeholder="Enter your email"
                required
            >

            <label for="password">Password</label>
            <input 
                type="password" 
                id="password" 
                name="password"
                placeholder="Create a password"
                required
            >

            <label for="age">Age</label>
            <input 
                type="number" 
                id="age" 
                name="age"
                placeholder="Enter your age"
            >

            <label for="weight">Weight (kg)</label>
            <input 
                type="number" 
                step="0.1"
                id="weight" 
                name="weight"
                placeholder="Enter your weight"
            >

            <label for="height">Height (cm)</label>
            <input 
                type="number" 
                step="0.1"
                id="height" 
                name="height"
                placeholder="Enter your height"
            >

            <div class="terms">
                <input 
                    type="checkbox" 
                    id="terms" 
                    required
                >

                <label for="terms">
                    I agree to the 
                    <a href="#">Terms & Conditions</a>
                </label>
            </div>

            <button type="submit">
                Register
            </button>

        </form>

        <div class="login-link">
            Already have an account?
            <a href="/login">Login</a>
        </div>

    </div>

</div>

<%- include('partials/footer') %>

</body>
</html>