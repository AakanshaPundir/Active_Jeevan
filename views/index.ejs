<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AG1</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap');
  /* I imported poppins from google fonts*/
  *{
    margin: 0%;
    padding: 0%;
    font-family: 'Poppins',sans-serif;
    box-sizing: border-box;
    outline: none;
    scroll-behavior: smooth;
  }
  :root{
    --prime:rgb(149, 234, 229);
  }
  body{
  
    background-color: #131b2b;
    color: white;
  }
  .navbar{
    width: 100%;
    display: flex;
    position: fixed;
    padding: 30px/*this is the padding for top and bottom and 120 is for left and rght*/ 120px;
    background-color: transparent;
    justify-content: space-between;
    z-index: 1111;
    transition: 0.5s ease;
  }
  .navbar.sticky{
    padding:6px 60px ;
    background: #0c1518;
    box-shadow: 0 0 15px rgba(0,0,0,0.5);
  }
  ol{
    display: flex;
    margin: auto 0;
  }
  ol li{
    margin-right: 20px;
    list-style: none;
  }
  ol li a{
    text-decoration:none ;
    font-size: 20px;
    font-weight: 500;
    color: white;
    text-transform: capitalize;
  }
  ol li:hover a{
    color: var(--prime);
  }
  /*home section*/

.home{
  display: flex;
  min-height: 120vh;
  align-items: center;
  justify-content: center;
  
  clip-path: polygon(0 0,100% 0,100% 100%,80% 95%,0 100% );
  
}
.banner{
  height: 100%;
  width: 100%;
  position: absolute;
  background: url(https://cdn.pixabay.com/photo/2017/01/16/15/28/boxer-1984344_1280.jpg);
  background-size: cover;
  background-position: center;
}
.highlights{
  width: 70%;
  position: relative;
  display:inline-block;
  z-index: 11;
  color: white;
}
.highlights h3{
  display: inline;
  font-size: 2vw;
  padding: 5px 20px;
  font-weight: lighter;
  text-transform: capitalize;
  border-left:6px solid var(--prime) ;
}
.highlights h1{
  font-size: 9vw;
  text-align: center;
  font-weight: normal;
}
.join{
  position: absolute;
  font-weight: 800;
  padding: 5px 20px;
  font-size: 1.5vw;
  margin-top: 1.2em;
  color: var(--prime);
  border: 2px solid var(--prime);
  border-radius: 50px;
  background: transparent;
  text-transform: capitalize;
}
.join:hover{
  color:black;
  background: var(--prime);
}
.view{
  width: 100%;
  min-height: 100vh;
  position: relative;
}
/*About section styling*/
.about{
  background-color: rgb(8, 8, 20);
  color: aliceblue;
}
.main{
  width: 100%;
  text-align: center;
  padding-bottom: 20px;
  color: white;
}
.main h2{
  font-size: 2.5vw;
  position: relative;
  text-align: center;
  padding-top: 100px;
  display: inline-block;
}
span{
  color: var(--prime);
}
.main h6{
  margin-top: 10px;
  font-size: 13px;
  font-family: sans-serif;
  font-weight: lighter;
}
.content{
  position: relative;
  display: flex;
  width: 100%;
  padding: 0 30px;
  justify-content: center;
}
.about .content .cols{
position: relative;
width: 100%;
height: 100%;
padding:20px 70px ;
}
.about .content .cols .box{
position: relative;
height: 550px;
box-shadow: 0 10px 10px rgba(0,0,0,0.5);
}
.about .content .cols .box img{
position: absolute;
top: 0;
left: 0;
height: 100%;
width: 100%;
object-fit: cover;
}

/*workout section*/
.workout .content{
  flex-wrap: wrap;
}
.workout .content .frame{
  position: relative;
  width: 350px;
  padding: 20px;
  margin: 10px;
  background: #222;
  box-shadow: 0 10px 15px rgba(0,0,0,0.5);
}
.workout .content .frame .box{
  position: relative;
  height: 200px;
  width: 100%;
  overflow: hidden;
}
.workout .content .frame .box img{
  position: relative;
  height: 100%;
  width: 100%;
  object-fit: cover;
  filter: brightness(80%);
  transition: 0.2s ease-in;
}
.workout .content .frame .box:hover img{
  filter: brightness(100%);
  transform: scale(1.08);
}
.workout .content .frame .title {
  font-size: 2vw;
  font-weight: bold;
  color: white; /* Ensure text is visible */
  margin-top: 10px;
}
.workout .content .frame p {
  color: white; /* Ensure the paragraph text is visible */
  font-size: 1.5vw;
}
/*links styling*/
a{
  text-decoration: none;
  color: var(--prime);
  font-weight: bolder;
}

/*trainer section*/
.trainer .content{
  flex-wrap: wrap;
}
.trainer .content .frame{
  position: relative;
  width:500px;
  padding: 30px 30px 40px 30px;
  box-shadow: 0 10px 15px rgba(0,0,0,0.5) ;
  margin: 10px;
  background: #222;
}
.trainer .content .frame .box{
  position: relative;
  height: 300px;
  width: 100%;
  overflow:hidden ; 
}
.trainer .content .frame .box img{
  position: absolute;
  height: 100%;
  width: 100%;
  filter: grayscale(1);
  object-fit: cover;
  transition: 0.2s ease-in;
}
.trainer .content .frame .box:hover img{
  filter: grayscale(0);
  transform: scale(1.08);
}
.trainer .content .frame .headline{
  display: flex;
  justify-content: space-between;
  align-items:center ;
  margin:8px 0 ; 
}
.trainer .content .frame .headline .title{
  color: var(--prime);
  font-size: 1.2em;
}
.trainer .content .frame p{
  font-size: 0.8em;
  position: relative;
  bottom: 5px;
}
/*diets section*/
.diet .content .row{
  display:flex ;
  position: relative;
  width: 100%;
  padding:20px 0;
  justify-content: center;
}
.diet .content .row .cols{
  position: relative;
  width: 600px;
  padding: 20px 50px;
}
.diet .content .row .cols .heading{
  font-size: 2em;
  color: rgb(240, 190, 65);
}
.diet .content .row .cols .boxes{
  position: relative;
  width: 100%;
  height: 350px;
  padding: 20px;
  border-radius: 8px;
  background: #fff;
  box-shadow: 0 10px 15px rgba(0,0,0,0.5);
}
.diet .content .row .cols .boxes img{
  height: 100%;
  width: 100%;
  object-fit: cover;
}
.diet .content{
  flex-direction: column;
}
.diet .content .row:nth-child(odd) .a{
  order:2 ;
}
/*copyright*/
.copyright{
  text-transform: capitalize;
  height: 40px;
  width: 100%;
  background: #222;
  
  text-align: center;
  font-size: 18px;
}


/*responsive design*/
@media screen and (max-width:900px){
  .navbar{
    padding: 0 60px;
  }
  .navbar ol{
    display: none;
  }
  .navbar ol.active{
    top: 60px;
    left: 0;
    width: 100%;
    display: flex;
    position: fixed;
    background: #222;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    height:calc(100% - 60px) ;
  }
  .navbar ol.active li{
    margin: 8px;
  }
  .navbar ol.active li a{
    font-size: 25px;
  }

  .navbar .toggle{
    height: 25px;
    width: 25px;
    margin: auto 0;
    cursor: pointer;
    background: url(data:image/jpeg;base64,);
    background-size: cover;
    background-position: center;
    filter: invert(1);
    background-repeat: no-repeat;

  }
  .navbar .toggle.active{
    background: url(data:image/jpeg;base64,);
    background-size: 40px;
    background-position: center;
    cursor: pointer;
    cursor: pointer;
    filter: invert(1);
  }
  .highlights h3{
    font-size: 3vw;
    padding: 5px 10px;
    border-left: 3px solid var(--prime);

  }
  .highlights h1{
    font-size: 16vw;
  }
  .highlights .join{
    font-size: 1.8vw;
    border: 1px solid var(--prime);
  }
  .main h2{
    font-size: 1.5rem;
  }
  .main h6{
    font-size: 10px;
  }
  .about .content{
    flex-direction: column;
  }
  


}

</style>
</head>
